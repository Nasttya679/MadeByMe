@using MadeByMe.Domain.Entities
@model List<ApplicationUser>

@{
    ViewData["Title"] = "Адмін панель";
}


<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Адмін панель</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow-sm sticky top-0 z-10">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-orange-700 hover:text-orange-800 transition-colors">MadeByMe</a>
            <nav class="space-x-4">
                <a href="/" class="text-gray-600 hover:text-orange-600">Головна</a>
                @if (User.Identity!.IsAuthenticated)
                {
                    <a href="/Account/Profile" class="text-gray-600 hover:text-orange-600">Профіль</a>
                    <a href="/Cart" class="text-gray-600 hover:text-orange-600">Кошик</a>
                    @if (!User.IsInRole("Seller") && !User.IsInRole("Admin"))
                    {
                        <form action="/Account/BecomeSeller" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-yellow-600 hover:text-yellow-700">Стати продавцем</button>
                        </form>
                    }
                    <form action="/Account/Logout" method="post" class="inline">
                        <button type="submit" class="text-red-600 hover:text-red-700">Вийти</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="text-orange-600 font-medium hover:underline">Увійти</a>
                    <a href="/Account/Register" class="bg-orange-600 text-white px-3 py-1 rounded hover:bg-orange-700 transition">Реєстрація</a>
                }
            </nav>
        </div>
    </header>

    <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h2 class="text-2xl font-bold">Адмін панель</h2>

        <form asp-action="Index" method="get" class="flex gap-2 w-full md:w-auto items-center">
            <input type="text" 
                name="searchTerm" 
                value="@ViewData["CurrentFilter"]" 
                placeholder="Пошук..." 
                class="border border-gray-300 rounded-lg px-4 py-2 w-full md:w-64 text-black focus:outline-none focus:ring-2 focus:ring-orange-500" />
            
            <button type="submit" 
                    class="bg-orange-500 text-black font-bold px-6 py-2 rounded-lg hover:bg-orange-600 border border-orange-700 transition duration-200 shadow-sm whitespace-nowrap">
                Шукати
            </button>
            
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
            {
                <a href="/Admin/Index" 
                class="bg-orange-500 text-black font-bold px-6 py-2 rounded-lg hover:bg-orange-600 border border-orange-700 transition duration-200 shadow-sm whitespace-nowrap text-center no-underline">
                    Скинути
                </a>
            }
        </form>
    </div>

    <div class="bg-white shadow-md rounded-lg overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-100 border-b">
                    <th class="p-4 font-semibold">Username</th>
                    <th class="p-4 font-semibold">Email</th>
                    <th class="p-4 font-semibold text-center">Blocked</th>
                    <th class="p-4 font-semibold text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var user in Model)
                    {
                        <tr class="border-b hover:bg-gray-50 transition">
                            <td class="p-4">@user.UserName</td>
                            <td class="p-4">@user.Email</td>
                            <td class="p-4 text-center">
                                @if (user.IsBlocked)
                                {
                                    <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-bold uppercase">True</span>
                                }
                                else
                                {
                                    <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-bold uppercase">False</span>
                                }
                            </td>
                            <td class="p-4 text-right">
                                @if (!user.IsBlocked)
                                {
                                    <a href="/Admin/Block?id=@user.Id" class="text-red-600 hover:font-bold">Block</a>
                                }
                                else
                                {
                                    <a href="/Admin/Unblock?id=@user.Id" class="text-green-600 hover:font-bold">Unblock</a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="p-8 text-center text-gray-500">
                            Користувачів не знайдено за вашим запитом.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>