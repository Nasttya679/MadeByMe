@using MadeByMe.Domain.Entities
@model List<ApplicationUser>

@{
    ViewData["Title"] = "Адмін панель";
}

<div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
    <h2 class="text-3xl font-extrabold text-gray-900">Адмін панель</h2>

    <form asp-action="Index" method="get" class="flex gap-2 w-full md:w-auto items-center">
        <input type="text" name="searchTerm" value="@ViewData["CurrentFilter"]" placeholder="Пошук користувачів..." class="border border-gray-300 rounded-xl px-4 py-2 w-full md:w-64 text-black focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
        <button type="submit" class="bg-orange-600 text-white font-bold px-6 py-2 rounded-xl hover:bg-orange-700 transition shadow-sm whitespace-nowrap">
            Шукати
        </button>
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
        {
            <a href="/Admin/Index" class="bg-gray-200 text-gray-700 font-bold px-6 py-2 rounded-xl hover:bg-gray-300 transition shadow-sm whitespace-nowrap text-center no-underline">
                Скинути
            </a>
        }
    </form>
</div>

<div class="bg-white shadow-md rounded-2xl overflow-hidden border border-gray-100">
    <table class="w-full text-left border-collapse">
        <thead>
        <tr class="bg-gray-50 border-b border-gray-100 text-gray-600 text-sm uppercase tracking-wider">
            <th class="p-4 font-bold">Username</th>
            <th class="p-4 font-bold">Email</th>
            <th class="p-4 font-bold text-center">Status</th>
            <th class="p-4 font-bold text-right">Actions</th>
        </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
        @if (Model.Any())
        {
            @foreach (var user in Model)
            {
                <tr class="hover:bg-orange-50 transition duration-150">
                    <td class="p-4 font-medium text-gray-900">@user.UserName</td>
                    <td class="p-4 text-gray-600">@user.Email</td>
                    <td class="p-4 text-center">
                        @if (user.IsBlocked)
                        {
                            <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">Заблоковано</span>
                        }
                        else
                        {
                            <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">Активний</span>
                        }
                    </td>
                    <td class="p-4 text-right">
                        @if (!user.IsBlocked)
                        {
                            <a href="/Admin/Block?id=@user.Id" class="inline-flex items-center text-red-600 hover:text-red-800 font-semibold bg-red-50 hover:bg-red-100 px-3 py-1 rounded-lg transition">
                                <i class="fa-solid fa-ban mr-1"></i> Block
                            </a>
                        }
                        else
                        {
                            <a href="/Admin/Unblock?id=@user.Id" class="inline-flex items-center text-green-600 hover:text-green-800 font-semibold bg-green-50 hover:bg-green-100 px-3 py-1 rounded-lg transition">
                                <i class="fa-solid fa-unlock mr-1"></i> Unblock
                            </a>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" class="p-8 text-center text-gray-500">
                    <div class="flex flex-col items-center justify-center">
                        <i class="fa-solid fa-users-slash text-4xl mb-3 text-gray-300"></i>
                        <p>Користувачів не знайдено за вашим запитом.</p>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="mt-8 flex flex-wrap justify-end gap-4">
    <a href="/Admin/Complaints" class="inline-flex items-center bg-red-50 border border-red-200 text-red-600 font-bold px-6 py-3 rounded-xl hover:bg-red-100 transition shadow-sm">
        <i class="fa-solid fa-flag mr-2"></i> Скарги на розгляд
    </a>
    <a href="/Post/DeletedPosts" class="inline-flex items-center bg-gray-900 text-white font-bold px-6 py-3 rounded-xl hover:bg-gray-800 transition shadow-sm">
        <i class="fa-solid fa-trash-can mr-2 text-orange-500"></i> Видалені товари
    </a>
</div>