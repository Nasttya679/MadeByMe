@model List<MadeByMe.Domain.Entities.Order>

@{
    ViewData["Title"] = "Історія покупок";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Історія покупок – MadeByMe</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800">

    <header class="bg-white shadow-sm sticky top-0 z-10">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-orange-700 hover:text-orange-800 transition-colors">MadeByMe</a>
            <nav class="flex items-center flex-wrap justify-end gap-x-3 gap-y-2">
       
                @if (User.Identity!.IsAuthenticated && User.IsInRole("Seller"))
                {
                    <a href="/Post/Create" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-orange-100 hover:bg-orange-200 transition-colors duration-200" title="Додати товар">
                        <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                    </a>
                }
             
                <a href="/" class="text-gray-600 hover:text-orange-600">Головна</a>
                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Account/Profile" class="text-gray-600 hover:text-orange-600">Профіль</a>
                    <a href="/Cart" class="text-gray-600 hover:text-orange-600">Кошик</a>
               
                    @if (!User.IsInRole("Seller"))
                    {
                        <form action="/Account/BecomeSeller" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-yellow-600 hover:text-yellow-700">Стати продавцем</button>
                        </form>
                    }
                    <form action="/Account/Logout" method="post" class="inline">
                        <button type="submit" class="text-red-600 hover:text-red-700 ps-2">Вийти</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="text-orange-600 font-medium hover:underline">Увійти</a>
                    <a href="/Account/Register" class="bg-orange-600 text-white px-3 py-1 rounded hover:bg-orange-700 transition">Реєстрація</a>
                }
            </nav>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-10">Історія покупок</h2>

        @if (Model == null || !Model.Any())
        {
            <div class="bg-white rounded-2xl shadow-sm p-12 text-center border border-gray-100">
                <p class="text-gray-500">Ваша історія порожня.</p>
                <a href="/" class="text-orange-600 font-bold mt-4 inline-block">Перейти до покупок</a>
            </div>
        }
        else
        {
            @foreach (var order in Model)
            {
                <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 mb-10 overflow-hidden">
                    <div class="px-6 py-4 flex justify-between items-center border-b border-gray-50">
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Замовлення #@order.Id</span>
                            <span class="text-gray-300">|</span>
                            <span class="text-xs font-bold text-gray-500 uppercase">@order.CreatedAt.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("uk-UA"))</span>
                        </div>
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 text-[10px] font-black uppercase rounded-lg">PAID</span>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[9px] uppercase text-gray-400 font-extrabold border-b border-gray-50">
                                    <th class="px-6 py-3">Назва товару</th>
                                    <th class="px-6 py-3 text-center">Кількість</th>
                                    <th class="px-6 py-3 text-center">Ціна</th>
                                    <th class="px-6 py-3 text-right">Дія</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                                @foreach (var item in order.OrderItems)
                                {
                                    <tr>
                                        <td class="px-6 py-6 font-bold text-gray-900 text-sm">@(item.Post?.Title ?? "Товар")</td>
                                        <td class="px-6 py-6 text-center text-sm font-medium text-gray-600">@item.Quantity шт.</td>
                                        <td class="px-6 py-6 text-center font-bold text-gray-900 text-sm">@item.PriceAtPurchase.ToString("N2") ₴</td>
                                        <td class="px-6 py-6 text-right">
                                            <a href="/Post/Details/@item.PostId" class="bg-orange-500 hover:bg-orange-600 text-white text-[10px] font-black px-4 py-2 rounded-xl uppercase transition-transform active:scale-95">Деталі</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="bg-orange-50/20 px-6 py-4 flex justify-end items-center gap-4 border-t border-orange-100/50">
                        <span class="text-[10px] font-bold text-orange-800 uppercase tracking-wider">Всього до сплати</span>
                        <span class="text-2xl font-black text-orange-600">@order.TotalAmount.ToString("N2") ₴</span>
                    </div>
                </div>
            }
        }
    </main>

</body>
</html>