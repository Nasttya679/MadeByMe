@model MadeByMe.Domain.Entities.Order
@{
    ViewData["Title"] = "Скасування замовлення";
}

<div class="max-w-3xl mx-auto py-12 px-4">
    <div class="bg-white rounded-3xl shadow-xl border border-red-100 overflow-hidden">
        
        <div class="bg-red-50 p-8 text-center border-b border-red-100 relative overflow-hidden">
            <i class="fa-solid fa-triangle-exclamation absolute -right-4 -bottom-8 text-9xl text-red-100 opacity-50 transform rotate-12"></i>
            
            <div class="relative z-10">
                <div class="w-20 h-20 bg-white text-red-500 rounded-full flex items-center justify-center mx-auto mb-5 text-3xl shadow-md border border-red-100">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h1 class="text-3xl font-extrabold text-red-800 mb-2">Скасування замовлення #@Model.Id</h1>
                <p class="text-red-600 font-medium">Ви дійсно бажаєте назавжди скасувати це замовлення?</p>
            </div>
        </div>

        <div class="p-8 md:p-10">
            <div class="bg-gray-50 rounded-2xl p-6 mb-8 border border-gray-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                    <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1">Дата оформлення</p>
                    <p class="font-bold text-gray-800 flex items-center text-lg">
                        <i class="fa-regular fa-calendar text-orange-500 mr-2"></i> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </p>
                </div>
                <div class="sm:text-right w-full sm:w-auto border-t sm:border-t-0 pt-4 sm:pt-0 border-gray-200">
                    <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1">Загальна сума</p>
                    <div class="flex items-baseline sm:justify-end gap-1">
                        <span class="text-3xl font-black text-orange-600">@Model.TotalAmount.ToString("N2")</span>
                        <span class="text-lg font-black text-orange-600">₴</span>
                    </div>
                </div>
            </div>

            <form asp-controller="Order" asp-action="CancelConfirm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="mb-10">
                    <label class="flex justify-between items-center mb-2">
                        <span class="text-sm font-bold text-gray-800">Вкажіть причину скасування</span>
                        <span class="text-[10px] font-bold text-gray-500 bg-gray-100 px-2 py-1 rounded-lg uppercase tracking-wider">Необов'язково</span>
                    </label>
                    
                    <div class="relative">
                        <textarea name="reason" rows="3" placeholder="Наприклад: Знайшов інший варіант, помилився з товаром..."
                                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-400 focus:border-red-400 outline-none transition shadow-sm resize-none text-gray-700"></textarea>
                    </div>
                    <p class="text-xs text-gray-500 mt-2 flex items-start">
                        <i class="fa-solid fa-circle-info mt-0.5 mr-1.5 text-blue-400"></i>
                        Ця інформація допоможе продавцю покращити свій сервіс та товари в майбутньому.
                    </p>
                </div>

                <div class="flex flex-col-reverse sm:flex-row gap-3 sm:justify-end pt-6 border-t border-gray-100">
                    <a href="/Order/History" class="px-6 py-3.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-bold hover:bg-gray-50 hover:text-gray-900 transition text-center shadow-sm w-full sm:w-auto">
                        Ні, залишити
                    </a>
                    <button type="submit" class="px-6 py-3.5 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition shadow-md flex items-center justify-center w-full sm:w-auto">
                        <i class="fa-solid fa-ban mr-2"></i> Так, скасувати
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>