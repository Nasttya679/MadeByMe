@{
    ViewData["Title"] = "Дякуємо за покупку";
}

@Html.AntiForgeryToken()

<div class="max-w-2xl mx-auto py-12 text-center">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-10 transform transition-all hover:shadow-2xl">
        <div class="w-24 h-24 bg-green-100 text-green-500 rounded-full flex items-center justify-center text-5xl mx-auto mb-6">
            <i class="fa-solid fa-check-circle animate-bounce"></i>
        </div>
        
        <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Дякуємо за покупку!</h1>
        
        <div class="text-gray-600 space-y-2 mb-8 text-lg">
            <p>Ваше замовлення успішно оформлено та прийнято до обробки.</p>
            <p>Ми надіслали підтвердження на вашу електронну пошту.</p>
            <p>Наш менеджер зв'яжеться з вами найближчим часом.</p>
        </div>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/" class="bg-orange-600 text-white font-bold px-8 py-3 rounded-xl hover:bg-orange-700 transition shadow-lg flex items-center justify-center">
                <i class="fa-solid fa-house mr-2"></i> На головну
            </a>
            <button onclick="clearCartAndRedirect()" class="bg-white text-orange-600 border-2 border-orange-600 font-bold px-8 py-3 rounded-xl hover:bg-orange-50 transition shadow-sm flex items-center justify-center">
                <i class="fa-solid fa-clock-rotate-left mr-2"></i> Мої замовлення
            </button>
        </div>
    </div>
</div>

<script>
    function clearCartAndRedirect() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch('/Cart/ClearCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            }
        }).then(() => {
            window.location.href = '/Order/History';
        });
    }
</script>