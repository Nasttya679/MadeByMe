@model List<MadeByMe.Application.DTOs.WishlistItemDto>

@{
    ViewData["Title"] = "Моє обране";
}

<div class="max-w-5xl mx-auto py-8">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900">
            <i class="fa-solid fa-heart text-red-500 mr-2"></i> Моє обране
        </h1>
        <span class="text-gray-500 font-medium bg-gray-100 px-3 py-1 rounded-full">@Model.Count товарів</span>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-16 text-center">
            <div class="text-7xl text-gray-200 mb-6 animate-pulse">
                <i class="fa-regular fa-heart"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-800 mb-3">Ваш список бажань порожній</h2>
            <p class="text-gray-500 mb-8 max-w-md mx-auto">Здається, ви ще нічого не додали до обраного. Перейдіть до каталогу, щоб знайти унікальні вироби!</p>
            <a href="/Post" class="bg-orange-600 text-white px-8 py-3.5 rounded-xl font-bold hover:bg-orange-700 transition inline-block shadow-sm">
                Перейти до каталогу
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="wishlist-container">
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden flex flex-col transition hover:shadow-md" id="wishlist-item-@item.PostId">
                    <a href="/Post/Details/@item.PostId" class="block overflow-hidden h-48">
                        <img src="@item.PhotoUrl" alt="@item.Title" class="w-full h-full object-cover transition-transform duration-500 hover:scale-110" />
                    </a>
                    
                    <div class="p-5 flex-grow flex flex-col justify-between">
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 mb-1 line-clamp-1 hover:text-orange-600 transition">
                                <a href="/Post/Details/@item.PostId">@item.Title</a>
                            </h3>
                            <p class="text-2xl font-black text-orange-600 mb-4">@item.Price ₴</p>
                        </div>
                        
                        <div class="flex space-x-2 mt-auto">
                            <form action="/Cart/AddToCartSilent" method="post" class="flex-grow" onsubmit="return addToCartSilent(event, this)">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="postId" value="@item.PostId" />
                                <button type="submit" class="w-full bg-orange-600 text-white py-2.5 rounded-xl font-bold hover:bg-orange-700 transition text-sm flex items-center justify-center">
                                    <i class="fa-solid fa-cart-plus mr-2"></i> В кошик
                                </button>
                            </form>

                            <button type="button" onclick="removeWishlistItem(this, @item.PostId)" class="bg-red-50 text-red-600 px-4 py-2.5 rounded-xl hover:bg-red-100 transition border border-red-100" title="Видалити з обраного">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
