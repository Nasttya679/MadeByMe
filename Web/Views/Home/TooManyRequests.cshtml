@{
    Layout = "_Layout";
    ViewData["Title"] = "Зачекайте";
}

<div class="max-w-2xl mx-auto py-20 text-center">
    <div class="w-24 h-24 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
        <i class="fa-solid fa-clock"></i>
    </div>
    <h1 class="text-3xl font-black text-gray-900 mb-4">Перевищено ліміт запитів</h1>
    <p class="text-gray-600 mb-8">
        Ми отримали занадто багато звернень з вашої IP-адреси за короткий проміжок часу. Система захисту автоматично призупинила доступ. Зачекайте 60 секунд.
    </p>
    <a href="/" class="bg-orange-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-orange-700 transition shadow-lg">
        На головну
    </a>
</div>