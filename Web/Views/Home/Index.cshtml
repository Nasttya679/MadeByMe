@model List<MadeByMe.Application.DTOs.PostResponseDto>

@{
    ViewData["Title"] = "Головна";
}

<section class="relative bg-gradient-to-br from-orange-50 via-orange-100 to-white py-20 lg:py-28 rounded-3xl mb-12 mt-4 overflow-hidden shadow-sm border border-orange-100">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 rounded-full bg-orange-200 opacity-40 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-64 h-64 rounded-full bg-orange-300 opacity-30 blur-3xl"></div>

    <div class="relative max-w-4xl mx-auto px-6 text-center z-10">
        <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 mb-6 leading-tight tracking-tight">
            Ласкаво просимо до <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-orange-600">MadeByMe</span>
        </h1>
        <p class="text-xl text-gray-600 mb-10 leading-relaxed max-w-2xl mx-auto font-medium">
            Платформа, де майстри діляться своїми унікальними виробами. <br class="hidden md:block" />
            Придбайте ручну роботу або станьте її творцем.
        </p>

        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a href="/Account/Register" class="w-full sm:w-auto bg-orange-600 text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5">
                    Приєднатися
                </a>
                <a href="/Post" class="w-full sm:w-auto bg-white text-orange-600 border-2 border-orange-200 px-8 py-4 rounded-xl text-lg font-bold hover:border-orange-500 hover:bg-orange-50 transition shadow-sm">
                    Переглянути товари
                </a>
            </div>
        }
        else
        {
            <a href="/Post" class="inline-flex bg-orange-600 text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5">
                Перейти до каталогу
            </a>
        }
    </div>
</section>

<section class="mb-16">
    <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100 hover:shadow-xl transition transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm">
                <i class="fa-solid fa-gem text-2xl text-orange-600"></i>
            </div>
            <h3 class="text-xl font-extrabold text-gray-900 mb-3">Унікальні товари</h3>
            <p class="text-gray-500 font-medium">Кожен виріб – це оригінальна ручна робота від перевірених майстрів.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100 hover:shadow-xl transition transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm">
                <i class="fa-solid fa-basket-shopping text-2xl text-orange-600"></i>
            </div>
            <h3 class="text-xl font-extrabold text-gray-900 mb-3">Просте замовлення</h3>
            <p class="text-gray-500 font-medium">Замовлення займає кілька кліків. Все інтуїтивно та швидко.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-lg border border-gray-100 hover:shadow-xl transition transform hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-100 rounded-2xl flex items-center justify-center mb-6 shadow-sm">
                <i class="fa-solid fa-hand-holding-heart text-2xl text-orange-600"></i>
            </div>
            <h3 class="text-xl font-extrabold text-gray-900 mb-3">Підтримка авторів</h3>
            <p class="text-gray-500 font-medium">Купуючи вироби, ви підтримуєте розвиток незалежних творців.</p>
        </div>
    </div>
</section>

@if (Model != null && Model.Any())
{
    <section class="mb-12">
        <div class="flex justify-between items-end mb-8 border-b border-gray-100 pb-4">
            <h2 class="text-3xl font-extrabold text-gray-900 flex items-center">
                <i class="fa-solid text-orange-500 mr-3"></i> Популярні товари
            </h2>
            <a href="/Post" class="text-orange-600 font-bold hover:text-orange-700 transition flex items-center hidden sm:flex">
                Всі товари <i class="fa-solid fa-arrow-right ml-2"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var post in Model)
            {
                <a href="/Post/Details/@post.Id" class="group bg-white rounded-3xl shadow-md hover:shadow-xl border border-gray-100 overflow-hidden transition duration-300 transform hover:-translate-y-1 flex flex-col">
                    <div class="relative w-full h-56 bg-gray-100 overflow-hidden">
                        <img src="@post.PhotoUrl" alt="@post.Title" class="w-full h-full object-cover transition duration-500 group-hover:scale-110" />
                    </div>

                    <div class="p-6 flex-grow flex flex-col justify-between">
                        <div>
                            <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-orange-600 transition line-clamp-1">@post.Title</h3>
                            <p class="text-sm text-gray-500 font-medium mb-3">@post.SellerName?.UserName</p>
                        </div>

                        <div class="flex justify-between items-center mt-2">
                            <span class="text-xl font-black text-orange-600">@post.Price ₴</span>

                            <div class="flex items-center bg-gray-50 px-2 py-1 rounded-lg">
                                <i class="fa-solid fa-star text-yellow-400 text-xs mr-1"></i>
                                <span class="text-sm font-bold text-gray-700">@post.Rating.ToString("F1")</span>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>

        <div class="mt-6 text-center sm:hidden">
            <a href="/Post" class="inline-flex bg-orange-100 text-orange-700 px-6 py-3 rounded-xl font-bold hover:bg-orange-200 transition">
                Переглянути всі товари <i class="fa-solid fa-arrow-right ml-2 mt-1"></i>
            </a>
        </div>
    </section>
}