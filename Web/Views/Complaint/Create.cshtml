@model MadeByMe.Application.DTOs.ComplaintDto
@{
    ViewData["Title"] = "Поскаржитися";
}

<div class="max-w-2xl mx-auto py-12 px-4">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
        
        <div class="bg-red-50 p-8 text-center border-b border-red-100 relative overflow-hidden">
            <i class="fa-regular fa-flag absolute -right-4 -bottom-8 text-9xl text-red-100 opacity-50 transform -rotate-12"></i>
            
            <div class="relative z-10">
                <div class="w-16 h-16 bg-white text-red-500 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl shadow-sm border border-red-100">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h1 class="text-2xl font-extrabold text-red-800 mb-2">Поскаржитися</h1>
                <p class="text-red-700 font-medium text-sm">Допоможіть нам зробити платформу безпечнішою.</p>
            </div>
        </div>

        <div class="p-8 md:p-10">
            <form asp-controller="Complaint" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PostId" />
                <input type="hidden" asp-for="SellerId" />

                <div class="mb-6">
                    <label class="block text-sm font-bold text-gray-700 uppercase tracking-widest mb-2">Причина скарги <span class="text-red-500">*</span></label>
                    <select asp-for="Reason" class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm font-bold py-3.5 rounded-xl px-4 hover:border-gray-300 focus:outline-none focus:ring-2 focus:ring-red-400 focus:bg-white cursor-pointer transition shadow-sm" required>
                        <option value="" disabled selected>Оберіть причину...</option>
                        <option value="Шахрайство">Шахрайство</option>
                        <option value="Підробка / Копія">Підробка або Копія</option>
                        <option value="Заборонений товар">Заборонений товар</option>
                        <option value="Образливий контент">Образливий контент</option>
                        <option value="Спам">Спам</option>
                        <option value="Інше">Інше</option>
                    </select>
                    <span asp-validation-for="Reason" class="text-xs text-red-500 font-bold mt-1 block"></span>
                </div>

                <div class="mb-8">
                    <label class="flex justify-between items-center mb-2">
                        <span class="text-sm font-bold text-gray-700 uppercase tracking-widest">Деталі ситуації</span>
                        <span class="text-[10px] font-bold text-gray-400 bg-gray-100 px-2 py-1 rounded-lg uppercase tracking-wider">Необов'язково</span>
                    </label>
                    <textarea asp-for="Description" rows="4" placeholder="Опишіть проблему детальніше. Це допоможе модераторам швидше прийняти рішення..."
                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-red-400 focus:bg-white focus:border-red-400 outline-none transition shadow-sm resize-none text-gray-700"></textarea>
                </div>

                <div class="flex flex-col-reverse sm:flex-row gap-3 pt-6 border-t border-gray-100">
                    <a href="javascript:history.back()" class="px-6 py-3.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-bold hover:bg-gray-50 hover:text-gray-900 transition text-center shadow-sm w-full sm:w-auto">
                        Скасувати
                    </a>
                    <button type="submit" class="flex-1 px-6 py-3.5 bg-red-600 text-white rounded-xl font-bold hover:bg-red-700 transition shadow-md flex items-center justify-center">
                        <i class="fa-solid fa-paper-plane mr-2"></i> Надіслати скаргу
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>