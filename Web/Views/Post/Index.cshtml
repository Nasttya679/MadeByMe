@model List<MadeByMe.Application.DTOs.PostResponseDto>

@{
    ViewData["Title"] = "Каталог товарів";

    bool hasActiveFilters = !string.IsNullOrEmpty(ViewBag.CurrentSearch) ||
                            ViewBag.CurrentCategory != null ||
                            !string.IsNullOrEmpty(ViewBag.CurrentSort);
}

<div class="mb-8">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-4xl font-extrabold text-gray-900">Каталог товарів</h1>
            <p class="mt-2 text-gray-600 font-medium">Знайдіть унікальні ручні вироби від наших майстрів</p>
        </div>

        @if (User.IsInRole("Seller") || User.IsInRole("Admin"))
        {
            <a href="/Post/Create"
               class="inline-flex items-center px-5 py-2.5 rounded-xl shadow-md font-bold text-white bg-orange-600 hover:bg-orange-700 transition transform hover:-translate-y-0.5">
                <i class="fas fa-plus mr-2"></i> Додати товар
            </a>
        }
    </div>

    <div class="bg-white p-3 md:p-4 rounded-2xl shadow-sm border border-gray-100">
        <form asp-controller="Post" asp-action="Index" method="get">

            <div class="flex items-center gap-4 mb-4 px-2">
                <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Шукати:</span>

                <label class="relative flex items-center cursor-pointer">
                    <input type="radio" name="searchType" value="products" class="peer sr-only" onchange="this.form.submit()"
                           @(ViewBag.CurrentSearchType == "products" || string.IsNullOrEmpty(ViewBag.CurrentSearchType) ? "checked" : "")>
                    <div class="flex items-center gap-2 px-4 py-1.5 rounded-xl bg-transparent text-gray-500 font-medium peer-checked:bg-orange-50 peer-checked:text-orange-600 peer-checked:font-bold transition border border-transparent peer-checked:border-orange-200 hover:bg-gray-50">
                        <i class="fa-solid fa-box text-sm"></i> Товари
                    </div>
                </label>

                <label class="relative flex items-center cursor-pointer">
                    <input type="radio" name="searchType" value="sellers" class="peer sr-only" onchange="this.form.submit()"
                           @(ViewBag.CurrentSearchType == "sellers" ? "checked" : "")>
                    <div class="flex items-center gap-2 px-4 py-1.5 rounded-xl bg-transparent text-gray-500 font-medium peer-checked:bg-orange-50 peer-checked:text-orange-600 peer-checked:font-bold transition border border-transparent peer-checked:border-orange-200 hover:bg-gray-50">
                        <i class="fa-solid fa-store text-sm"></i> Продавців
                    </div>
                </label>
            </div>

            <div class="flex flex-col lg:flex-row gap-3 items-center">

                <div class="w-full lg:flex-1 relative">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch"
                           placeholder="@(ViewBag.CurrentSearchType == "sellers" ? "Введіть ім'я продавця..." : "Що ви шукаєте?")"
                           class="w-full pl-11 pr-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition font-medium text-gray-700">
                </div>

                <div class="w-full lg:w-auto min-w-[220px] relative">
                    <i class="fa-solid fa-layer-group absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <select name="categoryId" onchange="this.form.submit()"
                            class="w-full pl-11 pr-10 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 bg-white outline-none cursor-pointer font-medium text-gray-700 appearance-none">
                        <option value="">Всі категорії</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Categories)
                        {
                            <option value="@item.Value" selected="@(item.Value == ViewBag.CurrentCategory?.ToString() ? "selected" : null)">
                                @item.Text
                            </option>
                        }
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                </div>

                <div class="w-full lg:w-auto min-w-[220px] relative">
                    <i class="fa-solid fa-arrow-down-a-z absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <select name="sortBy" onchange="this.form.submit()"
                            class="w-full pl-11 pr-10 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 focus:border-orange-500 bg-white outline-none cursor-pointer font-medium text-gray-700 appearance-none">
                        <option value="" selected="@(ViewBag.CurrentSort == null ? "selected" : null)">Сортувати за</option>
                        <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">Найдешевші</option>
                        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">Найдорожчі</option>
                        <option value="rating" selected="@(ViewBag.CurrentSort == "rating" ? "selected" : null)">Найвищий рейтинг</option>
                        <option value="newest" selected="@(ViewBag.CurrentSort == "newest" ? "selected" : null)">Новинки</option>
                    </select>
                    <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                </div>

                <div class="w-full lg:w-auto flex gap-3">
                    <button type="submit" class="flex-1 lg:flex-none px-8 py-3 bg-orange-600 text-white rounded-xl hover:bg-orange-700 transition font-bold shadow-sm">
                        Знайти
                    </button>

                    @if (hasActiveFilters)
                    {
                        <a href="/Post" class="flex-1 lg:flex-none px-6 py-3 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition font-bold text-center border border-gray-200">
                            Очистити пошук
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">

    @if (!Model.Any())
    {
        <div class="col-span-full py-24 flex flex-col items-center justify-center bg-white rounded-3xl border border-gray-100 shadow-sm">
            <div class="w-24 h-24 bg-orange-50 rounded-full flex items-center justify-center mb-6 shadow-inner">
                <i class="fa-solid fa-box-open text-5xl text-orange-400"></i>
            </div>

            <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Нічого не знайдено</h2>
            <p class="text-gray-500 font-medium mb-8">За вашим запитом результатів немає.</p>

            @if(hasActiveFilters)
            {
                <a href="/Post" class="px-8 py-3 bg-orange-600 text-white rounded-xl font-bold hover:bg-orange-700 transition shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
                    Скинути все
                </a>
            }
        </div>
    }

    @foreach (var post in Model)
    {
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 p-4 border border-gray-100 flex flex-col">
            <div class="relative w-full h-56 mb-4">
                <a href="/Post/Details/@post.Id" class="block w-full h-full overflow-hidden rounded-xl bg-gray-100">
                    <img src="@post.PhotoUrl" alt="@post.Title" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                </a>

                <div class="absolute top-3 left-3 pointer-events-none">
                    <span class="px-3 py-1 rounded-full text-xs font-black bg-white/90 text-orange-600 uppercase tracking-wider shadow-sm backdrop-blur-sm">
                        @(post.CategoryName?.Name ?? "Ручна робота")
                    </span>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button type="button"
                            onclick="toggleWishlist(this, @post.Id)"
                            class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm w-10 h-10 flex items-center justify-center rounded-full shadow-sm hover:bg-white transition-all z-10 focus:outline-none group">

                        @if (post.IsFavorite)
                        {
                            <i class="fa-solid fa-heart text-xl text-red-500 transition-transform duration-300 group-hover:scale-110"></i>
                        }
                        else
                        {
                            <i class="fa-regular fa-heart text-xl text-gray-400 transition-transform duration-300 group-hover:scale-110"></i>
                        }
                    </button>
                }
            </div>

            <div class="flex-grow flex flex-col justify-between">
                <div>
                    <h3 class="text-lg font-bold text-gray-900 line-clamp-1 group-hover:text-orange-600 transition-colors">
                        <a href="/Post/Details/@post.Id">@post.Title</a>
                    </h3>
                    <a href="/Seller/Storefront/@post.SellerId" class="inline-flex items-center mt-1 text-sm text-gray-500 font-medium hover:text-orange-600 transition z-20 relative">
                        <i class="fa-solid fa-store mr-1"></i> @(post.SellerName?.UserName ?? "Майстер")
                    </a>
                </div>

                <div class="mt-4 flex items-center justify-between">
                    <p class="text-2xl font-black text-orange-600">@post.Price ₴</p>
                    <div class="flex items-center bg-gray-50 px-2 py-1 rounded-lg">
                        <i class="fas fa-star text-yellow-400 text-xs mr-1"></i>
                        <span class="text-sm font-bold text-gray-700">@post.Rating.ToString("F1")</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>