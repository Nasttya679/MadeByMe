@model List<MadeByMe.Application.DTOs.PostResponseDto>

@{
    ViewData["Title"] = "MadeByMe - Каталог товарів";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="bg-gray-50 text-gray-800">
    <header class="bg-white shadow-sm sticky top-0 z-10">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-orange-700 hover:text-orange-800 transition-colors">MadeByMe</a>
            <nav class="space-x-4">
                <a href="/" class="text-gray-600 hover:text-orange-600">Головна</a>
                @if (User.Identity!.IsAuthenticated)
                {
                    <a href="/Account/Profile" class="text-gray-600 hover:text-orange-600">Профіль</a>
                    <a href="/Cart" class="text-gray-600 hover:text-orange-600">Кошик</a>
                    @if (!User.IsInRole("Seller") && !User.IsInRole("Admin"))
                    {
                        <form action="/Account/BecomeSeller" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-yellow-600 hover:text-yellow-700">Стати продавцем</button>
                        </form>
                    }
                    <form action="/Account/Logout" method="post" class="inline">
                        <button type="submit" class="text-red-600 hover:text-red-700">Вийти</button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="text-orange-600 font-medium hover:underline">Увійти</a>
                    <a href="/Account/Register" class="bg-orange-600 text-white px-3 py-1 rounded hover:bg-orange-700 transition">Реєстрація</a>
                }
            </nav>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
        <div class="mb-8">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Каталог товарів</h1>
                    <p class="mt-2 text-gray-600">Знайдіть унікальні ручні вироби від наших майстрів</p>
                </div>
                @if (User.IsInRole("Seller") || User.IsInRole("Admin"))
                {
                    <a href="/Post/Create" 
                       class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition">
                        <i class="fas fa-plus mr-2"></i>
                        Додати товар
                    </a>
                }
            </div>
        </div>

        <div class="mb-8 bg-white p-4 rounded-xl shadow-sm">
            <form asp-controller="Post" asp-action="Index" method="get" class="flex flex-wrap gap-4 items-center">

                @* 1. Пошук (зберігаємо текст пошуку) *@
                <div class="flex-1 min-w-[250px] relative">
                    <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch"
                           placeholder="Що ви шукаєте?"
                           class="w-full pl-10 pr-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition">
                    <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
                </div>

                @* 2. Вибір категорії (зберігаємо вибрану категорію) *@
                <select name="categoryId" onchange="this.form.submit()"
                        class="px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 bg-white outline-none cursor-pointer">
                    <option value="">Всі категорії</option>
                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Categories)
                    {
                        <option value="@item.Value" selected="@(item.Value == ViewBag.CurrentCategory?.ToString() ? "selected" : null)">
                            @item.Text
                        </option>
                    }
                </select>

                @* 3. Сортування (зберігаємо вибране сортування) *@
                <select name="sortBy" onchange="this.form.submit()"
                        class="px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-orange-500 focus:border-orange-500 bg-white outline-none cursor-pointer">
                    <option value="" selected="@(ViewBag.CurrentSort == null ? "selected" : null)">Сортувати за</option>
                    <option value="price_asc" selected="@(ViewBag.CurrentSort == "price_asc" ? "selected" : null)">Найдешевші</option>
                    <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc" ? "selected" : null)">Найдорожчі</option>
                    <option value="rating" selected="@(ViewBag.CurrentSort == "rating" ? "selected" : null)">Найвищий рейтинг</option>
                    <option value="newest" selected="@(ViewBag.CurrentSort == "newest" ? "selected" : null)">Новинки</option>
                </select>

                <button type="submit" class="px-6 py-2 bg-orange-600 text-white rounded-lg hover:bg-orange-700 transition font-medium">
                    Застосувати
                </button>

                @* Кнопка скидання *@
                <a href="/Post" class="text-sm text-gray-500 hover:text-orange-600 underline">Скинути все</a>
            </form>
        </div>

        <div class="grid grid-cols-1 gap-y-10 gap-x-6 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
            @if (!Model.Any())
            {
                <div class="col-span-full py-20 text-center">
                    <i class="fas fa-search text-5xl text-gray-200 mb-4"></i>
                    <p class="text-xl text-gray-500">Товарів не знайдено за вашим запитом.</p>
                </div>
            }

            @foreach (var post in Model)
            {
                <div class="group relative bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 p-4 border border-gray-100">
                    <div class="aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-lg bg-gray-100">
                        <img src="@post.PhotoUrl" alt="@post.Title" 
                             class="w-full h-48 object-cover rounded-lg transition-transform duration-500 group-hover:scale-110">

                        <div class="mt-2 flex items-center">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-orange-50 text-orange-700 border border-orange-100 uppercase tracking-wider">
                                @(post.CategoryName?.Name ?? "Ручна робота")
                            </span>
                        </div>
                    </div>
                    
                    <div class="mt-4 flex justify-between items-start">
                        <div class="flex-1 pr-2">
                            <h3 class="text-sm font-bold text-gray-900 line-clamp-1 group-hover:text-orange-600 transition-colors">
                                <a href="/Post/Details/@post.Id">
                                    <span aria-hidden="true" class="absolute inset-0"></span>
                                    @post.Title
                                </a>
                            </h3>
                            <p class="mt-1 text-xs text-gray-500">
                                <i class="far fa-user mr-1"></i> @(post.SellerName?.UserName ?? "Майстер")
                            </p>
                        </div>
                        <p class="text-lg font-bold text-orange-600">$@post.Price</p>
                    </div>

                    <div class="mt-3 flex items-center justify-between border-t border-gray-50 pt-3">
                        <div class="flex items-center">
                            <div class="flex items-center text-[10px] space-x-0.5">
                                @for (int i = 0; i < 5; i++)
                                {
                                    if (i < Math.Round(post.Rating))
                                    {
                                        <i class="fas fa-star text-yellow-400"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-star text-gray-200"></i>
                                    }
                                }
                            </div>
                            <span class="ml-1.5 text-[10px] font-medium text-gray-400">@post.Rating.ToString("F1")</span>
                        </div>
                        <i class="fas fa-chevron-right text-gray-300 text-[10px] group-hover:text-orange-400 transition-colors"></i>
                    </div>
                </div>
            }
        </div>

        @if (Model.Count > 0)
        {
            <div class="mt-12 flex justify-center">
                <nav class="flex items-center space-x-2">
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-200 text-gray-400 hover:bg-orange-50 hover:text-orange-600 transition">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-orange-600 text-white font-bold shadow-md shadow-orange-200">1</button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-200 text-gray-600 hover:bg-orange-50 hover:text-orange-600 transition">2</button>
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg border border-gray-200 text-gray-400 hover:bg-orange-50 hover:text-orange-600 transition">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </nav>
            </div>
        }
    </main>
</body>
</html>