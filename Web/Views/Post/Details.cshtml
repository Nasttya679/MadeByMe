@model MadeByMe.Application.ViewModels.PostDetailsViewModel
@using Microsoft.AspNetCore.Identity
@using MadeByMe.Domain.Entities
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = Model.Post?.Title ?? "Деталі товару";
}

<div class="max-w-6xl mx-auto py-8">
    @if (Model?.Post == null)
    {
        <div class="text-center py-20 bg-white rounded-3xl shadow-sm border border-gray-100">
            <i class="fa-solid fa-box-open text-6xl text-gray-200 mb-4"></i>
            <h2 class="text-2xl font-bold text-gray-700">Товар не знайдено або видалено</h2>
            <a href="/Post" class="bg-orange-600 text-white px-6 py-3 rounded-xl font-bold mt-6 inline-block hover:bg-orange-700 transition">В каталог</a>
        </div>
    }
    else
    {
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden mb-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                <div class="relative bg-gray-50 border-r border-gray-100">
                    <img src="@(Model.Post.Photos?.FirstOrDefault()?.FilePath ?? "/images/default.jpg")" alt="@Model.Post.Title" class="w-full h-full min-h-[400px] md:max-h-[600px] object-cover">

                    <div class="absolute top-6 left-6">
                        <span class="px-4 py-1.5 rounded-full text-xs font-black bg-white text-orange-600 uppercase tracking-widest shadow-md">
                            @Model.Post.Category?.Name
                        </span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button"
                                onclick="toggleWishlist(this, @Model.Post.Id)"
                                class="absolute top-6 right-6 bg-white/90 backdrop-blur-sm w-12 h-12 flex items-center justify-center rounded-full shadow-md hover:bg-white transition-all z-10 focus:outline-none group">

                            @if (Model.IsFavorite)
                            {
                                <i class="fa-solid fa-heart text-2xl text-red-500 transition-transform duration-300 group-hover:scale-110"></i>
                            }
                            else
                            {
                                <i class="fa-regular fa-heart text-2xl text-gray-400 transition-transform duration-300 group-hover:scale-110"></i>
                            }
                        </button>
                    }
                </div>

                <div class="p-8 md:p-10 flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-4">
                            <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 leading-tight pr-4">@Model.Post.Title</h1>
                            <div class="bg-orange-50 text-orange-600 px-4 py-2 rounded-xl border border-orange-100 shadow-sm text-center">
                                <span class="block text-xs font-bold uppercase tracking-widest text-orange-400 mb-0.5">Ціна</span>
                                <span class="text-2xl font-black whitespace-nowrap">@Model.Post.Price ₴</span>
                            </div>
                        </div>

                        <div class="flex items-center mb-8 bg-gray-50 inline-flex px-4 py-2 rounded-xl">
                            <div class="flex items-center">
                                @for (int i = 0; i < 5; i++)
                                {
                                    <i class="fa-solid fa-star text-sm @(i < Math.Floor(Model.Post.Rating) ? "text-yellow-400" : "text-gray-300") mr-1"></i>
                                }
                            </div>
                            <span class="ml-2 font-bold text-gray-700">@Model.Post.Rating.ToString("F1")</span>
                            <span class="mx-3 text-gray-300">|</span>
                            <span class="text-sm font-medium text-gray-500">Відгуків: @(Model.CommentsList?.Count ?? 0)</span>
                        </div>

                        <div class="flex items-center mb-8 p-4 border border-gray-100 rounded-2xl">
                            <div class="h-12 w-12 rounded-full bg-gradient-to-br from-orange-100 to-orange-200 flex items-center justify-center text-orange-600 font-black text-xl">
                                @(string.IsNullOrEmpty(Model.Post.Seller?.UserName) ? "?" : Model.Post.Seller!.UserName.Substring(0, 1).ToUpper())
                            </div>
                            <div class="ml-4">
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Продавець</p>
                                <p class="text-lg font-bold text-gray-900">@(Model.Post.Seller?.UserName ?? "Невідомий майстер")</p>
                            </div>
                        </div>

                        <div class="mb-8">
                            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-3">Опис товару</h3>
                            <p class="text-gray-700 leading-relaxed font-medium">@Model.Post.Description</p>
                        </div>
                    </div>

                    <div class="space-y-4 pt-6 border-t border-gray-100">
                        @{
                            var currentUserId = UserManager.GetUserId(User);
                            var isAdmin = User.IsInRole("Admin");
                            var isOwner = currentUserId != null && currentUserId == Model.Post.SellerId;
                        }

                        @if (User.Identity?.IsAuthenticated == true && (isAdmin || isOwner))
                        {
                            <div class="flex flex-col sm:flex-row gap-3">
                                @if (isOwner)
                                {
                                    <a href="/Post/Edit/@Model.Post.Id" class="flex-1 text-center bg-white text-gray-700 border-2 border-gray-200 px-6 py-3 rounded-xl font-bold hover:border-gray-300 transition">
                                        <i class="fa-solid fa-pen mr-2"></i> Редагувати
                                    </a>
                                }
                                <form asp-controller="Post" asp-action="Delete" asp-route-id="@Model.Post.Id" method="post" class="flex-1">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full bg-red-50 text-red-600 border-2 border-red-100 px-6 py-3 rounded-xl font-bold hover:bg-red-100 transition" onclick="return confirm('Ви дійсно хочете видалити цей товар?');">
                                        <i class="fa-solid fa-trash-can mr-2"></i> Видалити
                                    </button>
                                </form>
                            </div>
                        }

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex flex-col sm:flex-row gap-4 mt-4">
                            <input type="hidden" name="PostId" value="@Model.Post.Id" />
                            <div class="bg-gray-50 px-4 py-2 rounded-xl border border-gray-200 flex items-center justify-between sm:w-1/3">
                                <label for="quantity" class="text-xs font-bold text-gray-500 uppercase tracking-widest">Кількість</label>
                                <select name="Quantity" id="quantity" class="bg-transparent font-bold text-gray-900 focus:outline-none cursor-pointer">
                                    @for (int i = 1; i <= 10; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="sm:w-2/3 bg-orange-600 text-white px-6 py-4 rounded-xl font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5 flex justify-center items-center">
                                <i class="fa-solid fa-cart-plus mr-2"></i> В кошик
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-10">
            <h2 class="text-2xl font-extrabold text-gray-900 mb-8 flex items-center">
                <i class="fa-regular fa-comments text-orange-500 mr-3"></i> Відгуки покупців (@(Model.CommentsList?.Count ?? 0))
            </h2>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Comment" asp-action="Create" method="post" class="bg-gray-50 p-6 rounded-2xl mb-10 border border-gray-100">
                    <input type="hidden" name="PostId" value="@Model.Post.Id" />
                    <input type="hidden" id="ratingInput" name="Stars" value="5" />

                    <div class="mb-4 flex items-center">
                        <label class="text-sm font-bold text-gray-700 uppercase tracking-widest mr-4">Оцінка:</label>
                        <div class="flex space-x-1" id="starRating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fa-solid fa-star text-2xl cursor-pointer text-yellow-400 hover:scale-110 transition" data-value="@i"></i>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <textarea name="Content" rows="3" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none font-medium" placeholder="Поділіться своїми враженнями від виробу..."></textarea>
                    </div>

                    <button type="submit" class="bg-gray-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-gray-800 transition shadow-sm">
                        Надіслати відгук
                    </button>
                </form>
            }

            <div class="space-y-6">
                @if (Model.CommentsList != null && Model.CommentsList.Any())
                {
                    foreach (var comment in Model.CommentsList)
                    {
                        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm relative group hover:border-orange-100 transition">
                            <div class="flex items-start justify-between mb-3">
                                <div class="flex items-center">
                                    <div class="h-10 w-10 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center font-bold text-gray-600">
                                        @(string.IsNullOrEmpty(comment.User?.UserName) ? "?" : comment.User!.UserName.Substring(0, 1).ToUpper())
                                    </div>
                                    <div class="ml-4">
                                        <p class="font-bold text-gray-900">@(comment.User?.UserName ?? "Анонім")</p>
                                        <div class="flex items-center mt-1">
                                            <div class="flex mr-2">
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    <i class="fa-solid fa-star text-xs @(i < comment.Stars ? "text-yellow-400" : "text-gray-200")"></i>
                                                }
                                            </div>
                                            <span class="text-xs font-bold text-gray-400">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                </div>

                                @if (User.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || UserManager.GetUserId(User) == comment.UserId))
                                {
                                    <form asp-controller="Comment" asp-action="Delete" asp-route-id="@comment.CommentId" method="post" class="opacity-0 group-hover:opacity-100 transition">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-50 text-red-500 hover:bg-red-100 hover:text-red-700 transition" onclick="return confirm('Видалити цей відгук?');" title="Видалити">
                                            <i class="fa-solid fa-trash-can text-sm"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                            <p class="text-gray-700 font-medium pl-14">@comment.Content</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-10 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
                        <i class="fa-regular fa-comment-dots text-4xl text-gray-300 mb-2"></i>
                        <p class="text-gray-500 font-medium">Поки немає відгуків. Будьте першим!</p>
                    </div>
                }
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const stars = document.querySelectorAll('#starRating i');
        const ratingInput = document.getElementById('ratingInput');

        if(stars.length > 0) {
            stars.forEach(star => {
                star.addEventListener('mouseover', function() {
                    highlightStars(this.getAttribute('data-value'));
                });
                star.addEventListener('mouseout', function() {
                    highlightStars(ratingInput.value);
                });
                star.addEventListener('click', function() {
                    ratingInput.value = this.getAttribute('data-value');
                    highlightStars(this.getAttribute('data-value'));
                });
            });

            function highlightStars(count) {
                stars.forEach(star => {
                    const value = star.getAttribute('data-value');
                    if (value <= count) {
                        star.classList.remove('text-gray-300');
                        star.classList.add('text-yellow-400');
                    } else {
                        star.classList.remove('text-yellow-400');
                        star.classList.add('text-gray-300');
                    }
                });
            }
        }
    });
</script>