@model IEnumerable<MadeByMe.Application.DTOs.PostResponseDto>

@{
    ViewData["Title"] = "Кошик товарів";
}

<div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight flex items-center">
            <i class="fa-solid fa-trash-can text-red-500 mr-3"></i> Видалені товари
        </h1>
        <p class="text-gray-500 mt-1">Тут знаходяться товари, які були приховані з вітрини магазину.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Post" asp-action="Index"
           class="inline-flex items-center text-blue-600 hover:text-blue-700 font-semibold transition bg-blue-50 px-4 py-2 rounded-lg border border-blue-100">
            <i class="fa-solid fa-list-ul mr-2"></i> Повернутися до каталогу
        </a>
    }
    else
    {
        <a asp-controller="Seller" asp-action="Storefront" asp-route-id="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
           class="inline-flex items-center text-orange-600 hover:text-orange-700 font-semibold transition bg-orange-50 px-4 py-2 rounded-lg border border-orange-100">
            <i class="fa-solid fa-arrow-left mr-2"></i> Повернутися до панелі продавця
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center mt-6">
        <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-5">
            <i class="fa-solid fa-box-open text-4xl text-gray-300"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800 mb-2">Кошик порожній</h2>
        <p class="text-gray-500 max-w-md mx-auto">У вас немає видалених товарів. Усі ваші активні вироби знаходяться в каталозі.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var post in Model)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group opacity-80 hover:opacity-100 transition duration-300">
                <div class="relative bg-gray-100">
                    <img src="@post.PhotoUrl" alt="@post.Title" class="object-cover w-full h-48 grayscale group-hover:grayscale-0 transition duration-300" />
                    
                    <div class="absolute top-3 right-3 bg-red-500/90 backdrop-blur-sm text-white text-xs font-bold px-2.5 py-1 rounded-md shadow-sm">
                        <i class="fa-solid fa-trash mr-1"></i> Видалено
                    </div>
                </div>
                
                <div class="p-5 flex-grow flex flex-col">
                    <div class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">
                        @(post.CategoryName?.Name ?? "Без категорії")
                    </div>
                    
                    <h3 class="text-lg font-bold text-gray-900 mb-1 line-clamp-1" title="@post.Title">
                        @post.Title
                    </h3>
                    
                    <div class="text-xl font-extrabold text-gray-900 mb-5 mt-auto">
                        @post.Price.ToString("C0", new System.Globalization.CultureInfo("uk-UA"))
                    </div>

                    <div class="mt-auto flex gap-2">
                        <form asp-controller="Post" asp-action="Restore" method="post" class="flex-grow">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@post.Id" />
                            <button type="submit" class="w-full bg-green-50 text-green-600 border border-green-200 rounded-xl py-2 font-bold hover:bg-green-500 hover:text-white hover:border-green-500 transition-all duration-200 flex justify-center items-center shadow-sm">
                                <i class="fa-solid fa-rotate-left mr-2"></i> Відновити
                            </button>
                        </form>

                        <form asp-controller="Post" asp-action="HardDelete" method="post" class="flex-shrink-0" onsubmit="return confirm('Ви впевнені, що хочете видалити цей товар назавжди? Цю дію неможливо скасувати!');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@post.Id" />
                            <button type="submit" title="Видалити назавжди" class="h-full px-4 bg-red-50 text-red-600 border border-red-200 rounded-xl font-bold hover:bg-red-600 hover:text-white hover:border-red-600 transition-all duration-200 flex justify-center items-center shadow-sm">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}