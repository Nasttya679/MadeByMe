@model MadeByMe.Application.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Кошик";
    var itemsCount = Model.Items?.Count ?? 0;
}

<div class="max-w-7xl mx-auto py-8">
    <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-extrabold text-gray-900">Кошик</h2>
        <span class="text-gray-600 font-medium bg-gray-100 px-4 py-1 rounded-full">@itemsCount товарів</span>
    </div>

    @if (itemsCount > 0)
    {
        <div class="grid lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
                    <div class="divide-y divide-gray-100">
                        @foreach (var item in Model.Items!)
                        {
                            <div class="p-6 flex flex-col sm:flex-row items-center sm:space-x-6 space-y-4 sm:space-y-0 hover:bg-orange-50 transition duration-150">
                                <img src="@item.Product!.ImageUrl" alt="@item.Product.Name" class="w-32 h-32 object-cover rounded-2xl shadow-sm" />
                                
                                <div class="flex-1 w-full text-center sm:text-left">
                                    <h3 class="text-xl font-bold text-gray-900 mb-1">@item.Product.Name</h3>
                                    <p class="text-sm text-gray-500 mb-4">Продавець: <span class="font-semibold text-gray-700">@(item.Product.Seller?.UserName ?? "Невідомо")</span></p>
                                    
                                    <div class="flex items-center justify-center sm:justify-start space-x-6">
                                        <form action="/Cart/UpdateQuantity" method="post" class="flex items-center bg-gray-50 border border-gray-200 rounded-xl p-1 shadow-sm">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.ProductId" />
                                            <button type="submit" name="action" value="decrease" class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 hover:bg-white hover:shadow-sm transition font-bold">-</button>
                                            <span class="w-10 text-center font-bold text-gray-900">@item.Quantity</span>
                                            <button type="submit" name="action" value="increase" class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-600 hover:bg-white hover:shadow-sm transition font-bold">+</button>
                                        </form>
                                        <span class="text-xl font-black text-orange-600">@(item.Product.Price * item.Quantity) ₴</span>
                                    </div>
                                </div>
                                
                                <form action="/Cart/RemoveFromCart" method="post" class="sm:self-start">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="postId" value="@item.ProductId" />
                                    <button type="submit" class="text-gray-400 hover:text-red-600 p-2 transition group" title="Видалити">
                                        <i class="fa-solid fa-trash-can text-xl group-hover:scale-110 transition"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-8 sticky top-24">
                    <h3 class="text-xl font-extrabold text-gray-900 mb-6 flex items-center">
                        <i class="fa-solid fa-receipt text-orange-500 mr-3"></i> Підсумок
                    </h3>
                    
                    <div class="space-y-4 mb-6">
                        <div class="flex justify-between text-gray-600 font-medium">
                            <span>Товари (@itemsCount)</span>
                            <span>@Model.TotalPrice ₴</span>
                        </div>
                        <div class="flex justify-between text-gray-600 font-medium">
                            <span>Доставка</span>
                            <span class="text-green-600 font-bold">Безкоштовно</span>
                        </div>
                    </div>
                    
                    <div class="border-t border-gray-100 pt-6 mb-8">
                        <div class="flex justify-between items-center">
                            <span class="text-lg font-bold text-gray-900">Разом</span>
                            <span class="text-3xl font-black text-orange-600">@Model.TotalPrice ₴</span>
                        </div>
                    </div>

                    <a href="/Order/Checkout" class="w-full flex items-center justify-center bg-orange-600 text-white py-4 rounded-xl font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5 mb-4">
                        Оформити замовлення <i class="fa-solid fa-arrow-right ml-2"></i>
                    </a>

                    <div class="text-center">
                        <a href="/Post" class="text-gray-500 hover:text-orange-600 font-semibold transition text-sm">
                            <i class="fa-solid fa-arrow-left mr-1"></i> Продовжити покупки
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-16 text-center max-w-2xl mx-auto mt-8">
            <div class="w-24 h-24 bg-gray-50 text-gray-300 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
                <i class="fa-solid fa-cart-shopping"></i>
            </div>
            <h3 class="text-2xl font-extrabold text-gray-900 mb-2">Ваш кошик порожній</h3>
            <p class="text-gray-500 mb-8">Додайте товари до кошика, щоб зробити замовлення. У нас багато цікавого!</p>
            <a href="/Post" class="inline-flex items-center justify-center bg-orange-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5">
                Перейти до каталогу
            </a>
        </div>
    }
</div>