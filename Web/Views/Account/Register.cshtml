@model MadeByMe.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="flex items-center justify-center py-8">
    <div class="bg-white shadow-xl rounded-2xl w-full max-w-lg p-8 border border-gray-100 transform transition-all hover:shadow-2xl">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-orange-100 text-orange-600 rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
                <i class="fa-solid fa-user-plus"></i>
            </div>
            <h2 class="text-3xl font-extrabold text-gray-900">Створити акаунт</h2>
            <p class="text-gray-500 mt-2">Приєднуйтесь до нашої спільноти</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm">
                @Html.ValidationSummary(false, "", new { @class = "list-disc pl-4" })
            </div>
        }

        <form method="post" action="/Account/Register" class="space-y-5">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="UserName" class="block text-sm font-semibold text-gray-700 mb-1">Ім'я користувача</label>
                <input asp-for="UserName" required
                       class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                       placeholder="Наприклад: ivan_handmade" />
                <span asp-validation-for="UserName" class="mt-1 text-sm text-red-600 font-medium"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-1">Електронна пошта</label>
                <input asp-for="Email" type="email" required
                       class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                       placeholder="your@email.com" />
                <span asp-validation-for="Email" class="mt-1 text-sm text-red-600 font-medium"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-1">Пароль</label>
                <input asp-for="Password" type="password" required
                       class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                       placeholder="Мінімум 6 символів" />
                <span asp-validation-for="Password" class="mt-1 text-sm text-red-600 font-medium"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-semibold text-gray-700 mb-1">Підтвердження пароля</label>
                <input asp-for="ConfirmPassword" type="password" required
                       class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                       placeholder="Повторіть пароль" />
                <span asp-validation-for="ConfirmPassword" class="mt-1 text-sm text-red-600 font-medium"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 mb-1">Телефон</label>
                    <input asp-for="PhoneNumber"
                           class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                           placeholder="+380..." />
                    <span asp-validation-for="PhoneNumber" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>

                <div>
                    <label asp-for="Address" class="block text-sm font-semibold text-gray-700 mb-1">Адреса</label>
                    <input asp-for="Address" required
                           class="block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" 
                           placeholder="Місто, вулиця..." />
                    <span asp-validation-for="Address" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>
            </div>

            <button type="submit" 
                    class="w-full bg-gradient-to-r from-orange-500 to-orange-600 text-white font-bold py-3 px-4 rounded-xl hover:from-orange-600 hover:to-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 shadow-md transform hover:-translate-y-0.5 transition mt-4">
                Зареєструватися
            </button>

            <p class="mt-6 text-sm text-center text-gray-600">
                Вже маєте обліковий запис? 
                <a href="/Account/Login" class="text-orange-600 font-bold hover:text-orange-700 hover:underline transition">Увійти</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}