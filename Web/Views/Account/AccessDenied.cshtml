@{
    ViewData["Title"] = "Доступ заборонено";
}

<div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <div class="w-24 h-24 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-5xl mb-6 shadow-sm">
        <i class="fa-solid fa-lock"></i>
    </div>
    
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Доступ обмежено</h1>
    <p class="text-gray-500 max-w-md mb-8 text-lg">
        Вибачте, але у вас немає прав для перегляду цієї сторінки. Зверніться до адміністратора або увійдіть під іншим акаунтом.
    </p>
    
    <a asp-controller="Home" asp-action="Index" 
       class="bg-orange-600 text-white px-8 py-3 rounded-full font-bold hover:bg-orange-700 transition shadow-lg transform hover:-translate-y-0.5 flex items-center">
        <i class="fa-solid fa-house mr-2"></i> На головну
    </a>
</div>