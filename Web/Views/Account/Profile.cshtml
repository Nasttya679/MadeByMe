@model MadeByMe.Domain.Entities.ApplicationUser

@{
    ViewData["Title"] = "Ваш профіль";
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Профіль - MadeByMe</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">
<header class="bg-white shadow-sm sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-orange-700 hover:text-orange-800 transition-colors">MadeByMe</a>
        <nav class="space-x-4 flex items-center">
            <a href="/" class="text-gray-600 hover:text-orange-600 font-medium">Головна</a>
            @if (User.Identity!.IsAuthenticated)
            {
                <a href="/Account/Profile" class="text-orange-600 font-medium">Профіль</a>
                <a href="/Cart" class="text-gray-600 hover:text-orange-600 font-medium">Кошик</a>
                <form action="/Account/Logout" method="post" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-red-600 hover:text-red-700 ps-2 font-medium">Вийти</button>
                </form>
            }
        </nav>
    </div>
</header>

<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
        <div class="relative h-48 bg-gradient-to-br from-orange-400 via-orange-500 to-rose-500 before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_50%_120%,rgba(255,255,255,0.1),rgba(255,255,255,0))] before:opacity-60">
            <div class="absolute -bottom-16 left-8">
                <div class="relative group">
                    <img src="@(Model.ProfilePicture ?? "/images/default-avatar.png")"
                         class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover bg-white"
                         alt="Профільне фото" />
                    <a href="/Account/EditProfile"
                       class="absolute bottom-0 right-0 bg-orange-600 text-white p-2 rounded-full shadow-lg hover:bg-orange-700 transition-all duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <div class="pt-20 pb-8 px-8">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h2 class="text-3xl font-black text-gray-900 tracking-tight uppercase">@Model.UserName</h2>
                    <p class="text-gray-500 font-medium">@Model.Email</p>
                </div>
                @if (User.IsInRole("Seller"))
                {
                    <span class="bg-orange-100 text-orange-700 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest border border-orange-200 shadow-sm">
                        Продавець
                    </span>
                }
            </div>

            <div class="grid md:grid-cols-2 gap-12">
                <div class="space-y-6">
                    <div>
                        <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Контактна інформація</h3>
                        <div class="space-y-3">
                            <div class="flex items-center text-gray-700 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                </svg>
                                <span class="text-sm font-bold">@Model.Email</span>
                            </div>
                            <div class="flex items-center text-gray-700 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
                                </svg>
                                <span class="text-sm font-bold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Не вказано" : Model.PhoneNumber)</span>
                            </div>
                            <div class="flex items-center text-gray-700 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-orange-500" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                                </svg>
                                <span class="text-sm font-bold">@(string.IsNullOrEmpty(Model.Address) ? "Адреса не вказана" : Model.Address)</span>
                            </div>
                        </div>
                    </div>

                    <div class="pt-2">
                        <a href="/Order/History" class="w-full flex items-center justify-center bg-gray-900 text-white px-6 py-4 rounded-2xl hover:bg-black transition shadow-lg active:scale-95 font-black uppercase text-[10px] tracking-widest">
                            Історія моїх покупок
                        </a>
                    </div>
                </div>

                <div>
                    <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Статистика</h3>
                    <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 shadow-sm">
                        <div class="space-y-4">
                            @if (User.IsInRole("Seller"))
                            {
                                <div class="flex items-center justify-between bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                                    <span class="text-gray-500 font-black text-[10px] uppercase tracking-tighter">Оформлено замовлень</span>
                                    <span class="font-black text-orange-600 text-xl">@ViewBag.OrdersCount</span>
                                </div>

                                <div class="flex items-center justify-between bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                                    <span class="text-gray-500 font-black text-[10px] uppercase tracking-tighter">Відгуків на товари</span>
                                    <span class="font-black text-orange-600 text-xl">@ViewBag.ReviewsCount</span>
                                </div>

                                <div class="pt-6 border-t border-gray-200 mt-2">
                                    <a href="/Seller/Orders" class="w-full flex items-center justify-center bg-orange-600 text-white px-6 py-4 rounded-2xl hover:bg-orange-700 transition shadow-lg shadow-orange-200 active:scale-95 font-black uppercase text-[10px] tracking-widest">
                                        Журнал замовлень
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="flex items-center justify-between bg-white p-5 rounded-2xl border border-gray-100 shadow-sm">
                                    <span class="text-gray-500 font-black text-[10px] uppercase tracking-tighter">Відгуків залишено</span>
                                    <span class="font-black text-orange-600 text-xl">0</span>
                                </div>
                                @if (!User.IsInRole("Admin"))
                                {
                                    <div class="pt-4 border-t border-gray-200">
                                        <form action="/Account/BecomeSeller" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="w-full bg-white text-orange-600 border border-orange-100 px-6 py-4 rounded-2xl hover:bg-orange-50 transition font-black uppercase text-[10px] tracking-widest flex items-center justify-center">
                                                Стати продавцем
                                            </button>
                                        </form>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>