@*не використовується більше*@
@model MadeByMe.Application.DTOs.UpdateProfileDto
@{
    ViewData["Title"] = "Редагування профілю";
}

<div class="max-w-3xl mx-auto py-8">
    <div class="bg-white rounded-3xl shadow-lg border border-gray-100 p-8">
        <div class="flex items-center border-b border-gray-100 pb-6 mb-6">
            <a href="/Account/Profile" class="w-10 h-10 rounded-full bg-gray-100 text-gray-500 flex items-center justify-center hover:bg-orange-100 hover:text-orange-600 transition mr-4">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="text-2xl font-extrabold text-gray-900">Редагування профілю</h2>
                <p class="text-gray-500 text-sm mt-1">Оновіть свої особисті дані та контактну інформацію</p>
            </div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm">
                @Html.ValidationSummary(false, "", new { @class = "list-disc pl-4" })
            </div>
        }

        <form asp-action="EditProfile" method="post" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="UserName" class="block text-sm font-semibold text-gray-700 mb-1">Ім'я користувача</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        <input asp-for="UserName" class="pl-10 block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" />
                    </div>
                    <span asp-validation-for="UserName" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-envelope"></i>
                        </div>
                        <input asp-for="Email" type="email" class="pl-10 block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition bg-gray-50" readonly title="Зміна Email тимчасово недоступна" />
                    </div>
                    <span asp-validation-for="Email" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>

                <div>
                    <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 mb-1">Телефон</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <input asp-for="PhoneNumber" class="pl-10 block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" placeholder="+380..." />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>

                <div>
                    <label asp-for="Address" class="block text-sm font-semibold text-gray-700 mb-1">Адреса доставки</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <input asp-for="Address" class="pl-10 block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" />
                    </div>
                    <span asp-validation-for="Address" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="ProfilePicture" class="block text-sm font-semibold text-gray-700 mb-1">URL аватара (посилання на картинку)</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-link"></i>
                        </div>
                        <input asp-for="ProfilePicture" class="pl-10 block w-full px-4 py-3 border border-gray-300 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition" placeholder="https://..." />
                    </div>
                    <span asp-validation-for="ProfilePicture" class="mt-1 text-sm text-red-600 font-medium"></span>
                </div>
            </div>

            <div class="flex items-center justify-end pt-6 mt-4 border-t border-gray-100">
                <a href="/Account/Profile" class="text-gray-500 hover:text-gray-800 font-medium mr-6 transition">
                    Скасувати
                </a>
                <button type="submit" class="bg-gradient-to-r from-orange-500 to-orange-600 text-white font-bold px-8 py-3 rounded-xl hover:from-orange-600 hover:to-orange-700 transition shadow-md transform hover:-translate-y-0.5">
                    Зберегти зміни
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}