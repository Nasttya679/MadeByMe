@model IEnumerable<MadeByMe.Application.DTOs.SellerOrderDto>

@{
    ViewData["Title"] = "Журнал замовлень";
    var currentStatus = ViewBag.CurrentStatus as string ?? "All";
    var search = ViewBag.Search as string;
    var date = ViewBag.Date as string;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<style>
    .flatpickr-day.selected { background: #ea580c !important; border-color: #ea580c !important; }
    .flatpickr-months .flatpickr-month { background: #ea580c !important; color: white !important; fill: white !important; }
    .flatpickr-calendar { border-radius: 1rem !important; border: none !important; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
</style>

<div class="max-w-6xl mx-auto py-10">
    <div class="mb-8">
        <div class="mb-5 text-center md:text-left">
            <h1 class="text-4xl font-extrabold text-gray-900 mb-2">Журнал замовлень</h1>
            <p class="text-gray-500 font-medium">Керуйте продажами та статусами замовлень клієнтів</p>
        </div>
        
        <div class="w-full overflow-x-auto pb-2">
            <div class="inline-flex bg-gray-100 p-1.5 rounded-xl shadow-inner min-w-full sm:min-w-0">
                @foreach (var s in new[] { ("All", "Усі"), ("Processing", "В обробці"), ("Shipped", "Відправлено"), ("Delivered", "Доставлено"), ("Cancelled", "Скасовано"), ("ReturnRequested", "Запит на повернення"), ("Refunded", "Повернено") })
                {
                    <a href="?status=@s.Item1&search=@search&date=@date"
                       class="px-4 py-2 rounded-lg text-sm font-bold transition-all whitespace-nowrap shrink-0 @(currentStatus == s.Item1 ? "bg-white text-orange-600 shadow-sm" : "text-gray-500 hover:text-gray-700")">
                        @s.Item2
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="mb-10">
        <form method="get" class="flex flex-wrap gap-3 bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
            <input type="hidden" name="status" value="@currentStatus" />

            <div class="relative flex-1 md:min-w-[300px]">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" name="search" value="@search" placeholder="Пошук за товаром..."
                       class="w-full pl-11 pr-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition" />
            </div>

            <div class="relative">
                <i class="fa-regular fa-calendar absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 z-10 pointer-events-none"></i>
                <input type="text" id="sellerDatePicker" name="date" value="@date" placeholder="Оберіть дату..."
                       class="pl-11 pr-4 py-2.5 border border-gray-200 rounded-xl focus:ring-2 focus:ring-orange-500 outline-none transition text-gray-600 bg-white cursor-pointer" />
            </div>

            <button type="submit" class="bg-orange-600 text-white px-6 py-2.5 rounded-xl font-bold hover:bg-orange-700 transition">
                Знайти
            </button>

            @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(date))
            {
                <a href="/Seller/Orders?status=@currentStatus" class="bg-gray-100 text-gray-600 px-5 py-2.5 rounded-xl font-bold hover:bg-gray-200 transition flex items-center">
                    Очистити пошук
                </a>
            }
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="bg-white rounded-3xl p-16 text-center border border-gray-100 shadow-sm">
            <div class="w-20 h-20 bg-orange-50 text-orange-400 rounded-full flex items-center justify-center mx-auto mb-6 text-4xl">
                <i class="fa-solid fa-clipboard-list"></i>
            </div>
            <h2 class="text-2xl font-bold text-gray-800">Замовлень не знайдено</h2>
            <p class="text-gray-500 mt-2 mb-6 font-medium">Спробуйте змінити умови пошуку або статус.</p>
            <a href="/Seller/Orders" class="inline-block bg-orange-600 text-white font-bold px-8 py-4 rounded-xl hover:bg-orange-700 transition shadow-lg">
                Скинути все
            </a>
        </div>
    }
    else
    {
        <div class="grid gap-8">
            @foreach (var order in Model)
            {
                <div class="bg-white rounded-3xl shadow-md border border-gray-100 overflow-hidden hover:shadow-lg transition-shadow duration-300">

                    <div class="bg-gray-50 px-8 py-5 flex flex-wrap justify-between items-center border-b border-gray-100 gap-4">
                        <div class="flex items-center gap-6">
                            <span class="text-sm font-bold text-gray-700 flex items-center">
                                <i class="fa-regular fa-calendar text-orange-500 mr-2"></i> @order.OrderDate.ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>

                        @{
                            var statusColor = order.Status switch {
                                "Processing" => "bg-blue-50 text-blue-700 border-blue-200",
                                "Shipped" => "bg-purple-50 text-purple-700 border-purple-200",
                                "Delivered" => "bg-green-100 text-green-700 border-green-200",
                                "Cancelled" => "bg-red-50 text-red-700 border-red-200",
                                "ReturnRequested" => "bg-yellow-50 text-yellow-700 border-yellow-200", 
                                "Refunded" => "bg-yellow-100 text-yellow-800 border-yellow-300",
                                _ => "bg-gray-50 text-gray-700 border-gray-200"
                            };
                            var statusUa = order.Status switch {
                                "Processing" => "В обробці",
                                "Shipped" => "Відправлено",
                                "Delivered" => "Доставлено",
                                "Cancelled" => "Скасовано",
                                "ReturnRequested" => "Запит на повернення",
                                "Refunded" => "Повернено",
                                _ => order.Status
                            };
                        }
                        <span class="px-4 py-1.5 @statusColor text-sm font-bold rounded-xl border shadow-sm">
                            @statusUa
                        </span>
                    </div>

                    <div class="p-8 grid md:grid-cols-12 gap-8">

                        <div class="md:col-span-5">
                            <h4 class="text-base font-bold text-gray-800 border-b border-gray-100 pb-2 mb-4 flex items-center">
                                <i class="fa-solid fa-box-open text-orange-500 mr-2"></i> Деталі товарів
                            </h4>
                            <div class="space-y-3">
                                @foreach (var item in order.Items)
                                {
                                    <div class="flex justify-between items-center bg-gray-50 p-3 rounded-xl border border-gray-100">
                                        <span class="text-sm font-semibold text-gray-900">@item.ProductName</span>
                                        <span class="text-xs font-bold text-orange-600 bg-orange-100 px-2 py-1 rounded-lg">@item.Quantity шт.</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="md:col-span-4">
                            <div class="bg-orange-50 rounded-2xl p-5 border border-orange-100 h-full">
                                <h4 class="text-sm font-bold text-orange-800 border-b border-orange-200 pb-2 mb-3 flex items-center">
                                    <i class="fa-solid fa-user text-orange-500 mr-2"></i> Клієнт та доставка
                                </h4>
                                <p class="text-lg font-bold text-gray-900">@order.BuyerName</p>
                                <p class="text-sm text-gray-700 font-medium mt-3 flex items-center">
                                    <i class="fa-solid fa-phone text-orange-400 mr-2 w-4"></i> @order.BuyerPhone
                                </p>
                                <p class="text-sm text-gray-600 mt-2 flex items-start">
                                    <i class="fa-solid fa-location-dot text-orange-400 mr-2 w-4 mt-1"></i>
                                    <span>@order.ShippingAddress</span>
                                </p>
                            </div>
                        </div>

                        <div class="md:col-span-3 flex flex-col justify-between">
                            <div class="text-right mb-6 md:mb-0">
                                <p class="text-sm font-bold text-gray-500 mb-1">Сума замовлення</p>
                                <p class="text-3xl font-black text-orange-600">@order.TotalPrice.ToString("N2") ₴</p>
                            </div>

                            @if (order.Status == "ReturnRequested")
                            {
                                <form asp-controller="Seller" asp-action="ApproveReturn" method="post" class="w-full">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white text-sm font-bold py-3 rounded-xl transition shadow-md">
                                        <i class="fa-solid fa-check-double mr-2"></i> Схвалити повернення
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-controller="Seller" asp-action="UpdateStatus" method="post" class="w-full">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                    <select name="newStatus" onchange="this.form.submit()"
                                            class="w-full bg-gray-50 border border-gray-200 text-gray-700 text-sm font-bold py-3 rounded-xl px-4 hover:border-gray-300 hover:bg-white focus:outline-none focus:ring-2 focus:ring-orange-500 cursor-pointer transition shadow-sm">
                                        <option value="" disabled selected>Змінити статус...</option>
                                        <option value="Processing">В обробці</option>
                                        <option value="Shipped">Відправлено</option>
                                        <option value="Delivered">Доставлено</option>
                                        <option value="Cancelled">Скасовано</option>
                                    </select>
                                </form>
                            }
                        </div>

                        @if (order.Status == "Cancelled" || order.Status == "ReturnRequested" || order.Status == "Refunded")
                        {
                            bool isReturn = order.Status == "ReturnRequested" || order.Status == "Refunded";
                            string? reasonText = isReturn ? order.ReturnReason : order.CancellationReason;
                            
                            <div class="md:col-span-12 mt-2 pt-6 border-t border-gray-100">
                                <div class="@(isReturn ? "bg-yellow-50 border-yellow-200" : "bg-red-50 border-red-100") rounded-2xl p-5 border flex items-start gap-4 shadow-sm">
                                    <div class="w-10 h-10 @(isReturn ? "bg-yellow-100 text-yellow-600" : "bg-red-100 text-red-500") rounded-full flex items-center justify-center shrink-0">
                                        <i class="fa-solid @(isReturn ? "fa-box-open" : "fa-circle-exclamation") text-lg"></i>
                                    </div>
                                    <div class="flex-1">
                                        <p class="text-xs font-bold @(isReturn ? "text-yellow-800" : "text-red-800") uppercase tracking-widest mb-1">
                                            Причина @(isReturn ? "повернення" : "скасування") покупцем
                                        </p>
                                        <p class="text-sm font-medium @(isReturn ? "text-yellow-700" : "text-red-700") italic">
                                            "@(string.IsNullOrEmpty(reasonText) ? "Клієнт не вказав причину." : reasonText)"
                                        </p>
                                    </div>
                                </div>
                            </div> 
                        }

                    </div>
                </div>
            }
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://npmcdn.com/flatpickr/dist/l10n/uk.js"></script>
<script>
    flatpickr("#sellerDatePicker", {
        locale: "uk",
        dateFormat: "Y-m-d",
        altInput: true,
        altFormat: "d.m.Y",
        disableMobile: "true"
    });
</script>