@using Microsoft.AspNetCore.Identity
@using MadeByMe.Domain.Entities
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="uk" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MadeByMe</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        body { font-family: 'Inter', sans-serif; }
        .gradient-orange { background: linear-gradient(135deg, #ff8c00 0%, #ed6a1d 100%); }
        .fade-out {
            transition: opacity 1s ease-out, transform 1s ease-out;
            opacity: 0;
            transform: translateY(-20px);
        }
    </style>
</head>
<body class="bg-gray-50 h-full flex flex-col text-gray-900">

<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center space-x-8">
                <a href="/" class="text-2xl font-extrabold text-orange-600 tracking-tight hover:text-orange-700 transition">
                    MadeByMe
                </a>

                <nav class="hidden md:flex space-x-6 items-center">
                    @* ДИНАМІЧНА КНОПКА ЗАЛЕЖНО ВІД РОЛІ *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        if (User.IsInRole("Seller"))
                        {
                            <a href="/Post/Create" class="flex items-center bg-orange-50 text-orange-600 px-3 py-1.5 rounded-lg font-bold text-sm hover:bg-orange-100 transition border border-orange-200 shadow-sm">
                                <i class="fa-solid fa-plus mr-2"></i> Додати товар
                            </a>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <a href="/Admin/Index" class="flex items-center bg-gray-900 text-white px-3 py-1.5 rounded-lg font-bold text-sm hover:bg-gray-800 transition shadow-sm">
                                <i class="fa-solid fa-screwdriver-wrench mr-2 text-orange-500"></i> Панель керування
                            </a>
                        }
                    }

                    <a href="/" class="text-gray-600 hover:text-orange-600 font-medium transition">Головна</a>
                    <a href="/Post" class="text-gray-600 hover:text-orange-600 font-medium transition">Каталог</a>
                </nav>
            </div>

            <div class="flex items-center space-x-6">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Cart" class="text-gray-600 hover:text-orange-600 font-medium transition flex items-center">
                        <i class="fa-solid fa-cart-shopping mr-2"></i> Кошик
                    </a>

                    <a href="/Account/Profile" class="flex items-center space-x-2 text-gray-700 hover:text-orange-600 transition group">
                        <div class="w-8 h-8 rounded-full gradient-orange flex items-center justify-center text-white font-bold text-xs shadow-sm group-hover:scale-110 transition">
                            @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                        <span class="font-semibold">Профіль</span>
                    </a>

                    <form action="/Account/Logout" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-gray-400 hover:text-red-600 transition" title="Вийти">
                            <i class="fa-solid fa-right-from-bracket"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a href="/Account/Login" class="text-gray-600 hover:text-orange-600 font-medium transition">Увійти</a>
                    <a href="/Account/Register" class="bg-orange-600 text-white px-5 py-2 rounded-full font-bold hover:bg-orange-700 transition shadow-sm">Реєстрація</a>
                }
            </div>
        </div>
    </div>
</header>

<main class="flex-grow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        @if (TempData["Success"] != null)
        {
            <div class="js-alert mb-6 p-4 bg-green-50 border-l-4 border-green-500 text-green-700 rounded-r-lg shadow-sm">
                <i class="fa-solid fa-circle-check mr-2"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="js-alert mb-6 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg shadow-sm">
                <i class="fa-solid fa-circle-exclamation mr-2"></i> @TempData["Error"]
            </div>
        }

        @RenderBody()
    </div>
</main>

<partial name="_Footer" />

<script>
    document.addEventListener("DOMContentLoaded", function() {
        setTimeout(function() {
            const alerts = document.querySelectorAll('.js-alert');
            alerts.forEach(alert => {
                alert.classList.add('fade-out');
                setTimeout(() => alert.remove(), 1000);
            });
        }, 5000);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>