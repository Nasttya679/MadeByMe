@model MadeByMe.Application.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "Помилка";
}

<div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <div class="w-24 h-24 bg-red-100 text-red-600 rounded-full flex items-center justify-center text-5xl mb-6 shadow-sm animate-pulse">
        <i class="fa-solid fa-triangle-exclamation"></i>
    </div>
    
    <h1 class="text-4xl font-extrabold text-gray-900 mb-4">Ой, сталася помилка!</h1>
    
    <p class="text-gray-600 max-w-md mx-auto mb-8 text-lg">
        На жаль, ваш запит не може бути виконано. Можливо, щось пішло не так на сервері. Ми вже працюємо над цим!
    </p>

    @if (Model?.ShowRequestId == true)
    {
        <div class="bg-gray-100 px-6 py-3 rounded-lg text-sm text-gray-700 font-mono shadow-inner mb-8 border border-gray-200">
            <span class="text-gray-500 mr-2">ID запиту:</span> <strong>@Model.RequestId</strong>
        </div>
    }

    <a href="/" class="bg-orange-600 text-white px-8 py-3 rounded-full font-bold hover:bg-orange-700 transition shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
        Повернутися на головну
    </a>
</div>